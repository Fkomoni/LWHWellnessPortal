# Frontend environment variables
# For local dev: requests proxy through Vite to localhost:3001 (see vite.config.ts)
# For Render: set VITE_API_URL to your deployed backend URL

# Leave empty for local dev (Vite proxy handles it)
# VITE_API_URL=https://lwh-wellness-api.onrender.com/api

# For local dev using the Vite proxy, leave this commented out.
# VITE_API_URL defaults to /api which is proxied to http://localhost:3001
