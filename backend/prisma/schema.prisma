// Leadway Wellness Portal — Prisma Schema
// Azure SQL (production) / PostgreSQL (Render prototype)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ENROLLEE
  PROVIDER
  ADVOCATE
}

enum OtpPurpose {
  AUTH
  SESSION
  PROVIDER_AUTH // daily email OTP for provider portal second-factor
}

enum OtpGeneratedBy {
  MEMBER
  PROVIDER // flagged — provider generated on behalf of member
  ADVOCATE // advocate generated — sent to member+provider via email
}

enum SessionStatus {
  CONFIRMED
  PENDING
  FLAGGED
  CANCELLED
}

enum ClaimStatus {
  PENDING     // session validated, claim auto-created
  SUBMITTED   // provider submitted batch
  APPROVED    // processed for payment
  REJECTED
  REVERSED    // FWA case closed → auto-reversed
}

enum FwaStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

enum ProviderStatus {
  ACTIVE
  SUSPENDED
  PENDING_REVIEW
}

enum WhatsAppResponseType {
  YES
  NO
}

enum NotificationChannel {
  WHATSAPP
  EMAIL
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

model Member {
  id               String    @id @default(cuid())
  memberRef        String    @unique
  firstName        String
  lastName         String
  phone            String    @unique
  email            String?   @unique
  role             Role      @default(ENROLLEE)
  isActive         Boolean   @default(true)
  sessionsPerMonth    Int       @default(1)   // weekly session limit — synced from Prognosis
  annualSessionLimit  Int       @default(0)   // raw annual figure from Prognosis WellnessBenefit API
  sessionsUsed        Int       @default(0)
  resetDate        DateTime?
  spouseId         String?
  planType         String    @default("STANDARD") // STANDARD | PREMIUM
  schemeId         String?   // Prognosis SchemeID — cached on login for gym lookup
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  sessions         Session[]
  otpRecords       OtpRecord[]
  auditLogs        AuditLog[]
  ratings          GymRating[]
  refreshTokens    RefreshToken[]
  notifications    Notification[]
  topUps           TopUp[]

  @@index([phone])
  @@index([memberRef])
  @@map("members")
}

model Provider {
  id          String         @id @default(cuid())
  gymCode     String         @unique
  gymName     String
  phone       String?        @unique
  email       String?        @unique
  location    String?
  address     String?
  lga         String
  state       String         @default("Lagos")
  latitude    Float?
  longitude   Float?
  hours       Json?          // { mon: "6am-10pm", ... }
  amenities   String[]       // ["pool", "sauna", "classes", ...]
  status      ProviderStatus @default(ACTIVE)
  statusNote  String?        // reason for suspension
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  sessions    Session[]
  claims      Claim[]
  fwaCases    FwaCase[]
  payAdvices  PayAdvice[]

  @@index([gymCode])
  @@index([status])
  @@map("providers")
}

model Session {
  id              String         @id @default(cuid())
  memberId        String
  providerId      String
  sessionOtpId    String
  generatedBy     OtpGeneratedBy @default(MEMBER)
  status          SessionStatus  @default(PENDING)
  whatsappVerified Boolean       @default(false)
  whatsappSentAt  DateTime?
  memberResponse  WhatsAppResponseType?
  memberResponseAt DateTime?
  lastVisitDate   DateTime?      // captured when member says No
  fwaFlagged      Boolean        @default(false)
  sessionDate     DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  member   Member   @relation(fields: [memberId], references: [id])
  provider Provider @relation(fields: [providerId], references: [id])
  claim    Claim?
  rating   GymRating?
  fwaCase  FwaCase?

  @@index([memberId])
  @@index([providerId])
  @@index([sessionDate])
  @@map("sessions")
}

model OtpRecord {
  id            String         @id @default(cuid())
  memberId      String?
  phone         String
  otpHash       String
  purpose       OtpPurpose
  generatedBy   OtpGeneratedBy @default(MEMBER)
  generatedById String?        // advocate/provider userId who generated it
  expiresAt     DateTime
  usedAt        DateTime?
  attempts      Int            @default(0)
  ipAddress     String?
  createdAt     DateTime       @default(now())

  member Member? @relation(fields: [memberId], references: [id])

  @@index([phone, purpose])
  @@index([expiresAt])
  @@map("otp_records")
}

model RefreshToken {
  id        String   @id @default(cuid())
  memberId  String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  userRole   String?
  action     String
  resource   String
  resourceId String?
  ipAddress  String
  userAgent  String?
  status     String
  details    Json?
  timestamp  DateTime @default(now())

  member Member? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@map("audit_logs")
}

model Claim {
  id           String      @id @default(cuid())
  sessionId    String      @unique
  providerId   String
  amount       Float
  status       ClaimStatus @default(PENDING)
  submittedAt  DateTime?
  processedAt  DateTime?
  payAdviceId  String?
  reversedAt   DateTime?
  reversalNote String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  session   Session   @relation(fields: [sessionId], references: [id])
  provider  Provider  @relation(fields: [providerId], references: [id])
  payAdvice PayAdvice? @relation(fields: [payAdviceId], references: [id])

  @@index([providerId])
  @@index([status])
  @@map("claims")
}

// Pay advice = payment batch document for providers
model PayAdvice {
  id           String   @id @default(cuid())
  providerId   String
  reference    String   @unique // e.g. "PAY-2026-04-GYM001"
  periodStart  DateTime
  periodEnd    DateTime
  totalClaims  Int
  totalAmount  Float
  pdfPath      String?  // path/URL to generated PDF
  issuedAt     DateTime @default(now())
  createdAt    DateTime @default(now())

  provider Provider @relation(fields: [providerId], references: [id])
  claims   Claim[]

  @@index([providerId])
  @@map("pay_advices")
}

model FwaCase {
  id             String    @id @default(cuid())
  caseRef        String    @unique
  memberId       String
  providerId     String
  sessionId      String?   @unique
  flagType       String
  status         FwaStatus @default(OPEN)
  description    String
  investigatorId String?
  memberStatement String?  // what member said when they replied "No"
  lastVisitDate  DateTime? // member's stated last visit
  resolvedBy     String?
  resolvedAt     DateTime?
  resolution     String?   // resolution notes
  claimReversed  Boolean   @default(false)
  updatedAt      DateTime  @updatedAt
  createdAt      DateTime  @default(now())

  provider Provider @relation(fields: [providerId], references: [id])
  session  Session? @relation(fields: [sessionId], references: [id])

  @@index([status])
  @@index([memberId])
  @@map("fwa_cases")
}

model GymRating {
  id         String   @id @default(cuid())
  memberId   String
  sessionId  String   @unique
  providerId String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  member  Member  @relation(fields: [memberId], references: [id])
  session Session @relation(fields: [sessionId], references: [id])

  @@index([providerId])
  @@map("gym_ratings")
}

// In-app + push notification model
model Notification {
  id        String             @id @default(cuid())
  memberId  String
  title     String
  body      String
  channel   NotificationChannel
  status    NotificationStatus @default(PENDING)
  readAt    DateTime?
  sentAt    DateTime?
  metadata  Json?
  createdAt DateTime           @default(now())

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId, readAt])
  @@index([createdAt])
  @@map("notifications")
}

// Every email sent from any portal is logged here (regulatory requirement)
model CommunicationLog {
  id           String   @id @default(cuid())
  senderId     String   // userId of advocate/system
  senderName   String
  recipientId  String?  // memberId or external
  recipientEmail String
  subject      String
  body         String
  emailType    String   // "GYM_NETWORK_INFO" | "OTP_DELIVERY" | "FWA_NOTIFICATION" | etc.
  metadata     Json?
  sentAt       DateTime @default(now())
  createdAt    DateTime @default(now())

  @@index([senderId])
  @@index([recipientId])
  @@index([sentAt])
  @@map("communication_logs")
}

// Top-up / additional session purchases
model TopUp {
  id              String   @id @default(cuid())
  memberId        String
  sessionCount    Int      // number of sessions purchased
  amount          Float    // amount charged
  discountApplied Float    @default(0) // 20% Leadway discount
  plan            String   // "MONTHLY" | "QUARTERLY" | "ANNUAL"
  provider        String   @default("PAYSTACK") // payment gateway
  paymentRef      String   @unique // gateway reference
  status          String   @default("PENDING") // "PENDING" | "SUCCESS" | "FAILED"
  paidAt          DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  member Member @relation(fields: [memberId], references: [id])

  @@index([memberId])
  @@map("top_ups")
}

// WhatsApp incoming responses (webhook)
model WhatsAppMessage {
  id          String   @id @default(cuid())
  phone       String
  messageId   String   @unique // WhatsApp message ID
  body        String   // raw message content
  sessionId   String?  // linked session if matched
  processed   Boolean  @default(false)
  receivedAt  DateTime @default(now())

  @@index([phone])
  @@map("whatsapp_messages")
}
