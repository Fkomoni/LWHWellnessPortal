# ─── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ──────────────────────────────────────────────────────────────
# Render PostgreSQL (get from Render dashboard after creating DB)
DATABASE_URL=postgresql://user:password@host:5432/lwh_wellness?schema=public

# ─── JWT Secrets — generate with: node -e "require('crypto').randomBytes(64).toString('hex')"
# MUST be at least 32 characters. Use DIFFERENT values for each secret.
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET_HERE
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_SECRET_HERE
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,https://your-app.onrender.com

# ─── OTP Settings ──────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=120
OTP_MAX_ATTEMPTS=5
SESSION_OTP_LENGTH=6
BCRYPT_ROUNDS=12

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_API_MAX=100

# ─── Notifications (optional for prototype) ────────────────────────────────
# WHATSAPP_API_URL=https://api.360dialog.io/v1/messages
# WHATSAPP_API_KEY=your_360dialog_api_key
# SENDGRID_API_KEY=your_sendgrid_key

# ─── Dev Only — NEVER set to true in production ────────────────────────────
# Shows OTP in API response for testing without WhatsApp integration
OTP_VISIBLE_IN_DEV=true
