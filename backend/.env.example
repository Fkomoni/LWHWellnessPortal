# ─── Core ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/lwh_wellness?schema=public

# ─── JWT Secrets — node -e "require('crypto').randomBytes(64).toString('hex')"
JWT_ACCESS_SECRET=REPLACE_WITH_64_CHAR_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_CHAR_HEX_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,https://your-app.onrender.com

# ─── OTP Settings ──────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=120
OTP_MAX_ATTEMPTS=5
SESSION_OTP_LENGTH=6
BCRYPT_ROUNDS=12

# ─── Rate Limiting ─────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_AUTH_MAX=5
RATE_LIMIT_API_MAX=100

# ─── WhatsApp Business API (360Dialog or Twilio) ───────────────────────────
WHATSAPP_API_URL=https://waba.360dialog.io/v1/messages
WHATSAPP_API_KEY=your_360dialog_api_key
WHATSAPP_FROM_NUMBER=+2348000000000
# Webhook verify token (set same value in 360Dialog dashboard)
WHATSAPP_WEBHOOK_SECRET=your_webhook_secret_token

# ─── Email (SMTP) ──────────────────────────────────────────────────────────
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=wellness@leadway.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_EMAIL=wellness@leadway.com
SMTP_FROM_NAME=Leadway Wellness Portal
# Set SMTP_SECURE=true only if using port 465 (SSL). Leave false for port 587 (STARTTLS).
SMTP_SECURE=false

# ─── Payment (Paystack) ────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_key
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_key
PAYSTACK_WEBHOOK_SECRET=your_paystack_webhook_secret

# ─── Google Maps (gym location / map view) ─────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_key

# ─── App URL (used in emails/links) ────────────────────────────────────────
APP_URL=http://localhost:5173

# ─── Session timeout (minutes of inactivity before re-auth prompt) ─────────
SESSION_IDLE_TIMEOUT_MINUTES=30

# ─── Dev Only — NEVER true in production ───────────────────────────────────
OTP_VISIBLE_IN_DEV=true
